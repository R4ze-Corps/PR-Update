{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./build",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "#base": ["./src/discord/base/index.ts"],
      "#functions": ["./src/functions/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build"]
}
